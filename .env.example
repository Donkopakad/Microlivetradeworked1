# Default is safe paper trading. No live Binance orders are placed while DRY_RUN=true.
DRY_RUN=true

# Binance API credentials are only required when DRY_RUN=false.
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Strategy settings.
TRADE_USDT_SIZE=25
LEVERAGE=1
MARGIN_MODE=isolated
POLL_SECONDS=10
TRADE_HISTORY_CSV=trade_history.csv
